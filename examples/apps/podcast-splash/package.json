{
  "name": "podcast-splash",
  "version": "0.1.0",
  "private": true,
  "description": "Generate podcast speaker splash intros — renders YouTube (16:9) and Reel (9:16) MP4s from one responsive template",
  "type": "module",
  "bin": {
    "podcast-splash": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node --enable-source-maps dist/cli.js",
    "dev": "tsx src/cli.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "superimg": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3"
  }
}
