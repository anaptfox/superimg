{
  "name": "git-history-video",
  "version": "0.1.0",
  "private": true,
  "description": "Generate a timeline video from your git history",
  "type": "module",
  "bin": {
    "git-history-video": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node --enable-source-maps dist/cli.js",
    "dev": "tsx src/cli.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "superimg": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3"
  }
}
