  "scripts": {
    "build": "tsup && node scripts/verify-build-artifacts.mjs",
    "dev": "tsup --watch",
    "test": "vitest --run --passWithNoTests",
    "clean": "rm -rf dist",
    "verify:build": "node scripts/verify-build-artifacts.mjs"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "video",
    "rendering",
    "html",
    "css",
    "animation",
    "programmatic"
