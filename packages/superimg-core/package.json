{
  "name": "@superimg/core",
  "version": "0.1.0",
  "description": "Core environment-agnostic primitives for SuperImg",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./html": {
      "import": "./dist/html.js",
      "types": "./dist/html.d.ts"
    },
    "./bundler": {
      "import": "./dist/bundler.js",
      "types": "./dist/bundler.d.ts"
    },
    "./bundler-browser": {
      "import": "./dist/bundler-browser.js",
      "types": "./dist/bundler-browser.d.ts"
    },
    "./engine": {
      "import": "./dist/engine.js",
      "types": "./dist/engine.d.ts"
    },
    "./template-metadata": {
      "import": "./dist/template-metadata.js",
      "types": "./dist/template-metadata.d.ts"
    },
    "./bundler-plugin": {
      "import": "./dist/bundler-plugin.js",
      "types": "./dist/bundler-plugin.d.ts"
    },
    "./validation": {
      "import": "./dist/validation.js",
      "types": "./dist/validation.d.ts"
    }
  },
  "scripts": {
    "generate": "tsx scripts/generate-runtime.ts",
    "build": "pnpm run generate && tsup",
    "dev": "tsup --watch",
    "test": "vitest --run",
    "clean": "rm -rf dist src/generated"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "keywords": [
    "superimg",
    "core",
    "rendering",
    "video"
  ],
  "license": "MIT",
  "dependencies": {
    "@superimg/stdlib": "workspace:*",
    "@superimg/types": "workspace:*",
    "oxc-parser": "^0.119.0",
    "zod": "^4.3.5",
    "zustand": "^5.0.0"
  },
  "peerDependencies": {
    "esbuild-wasm": "^0.27.0"
  },
  "peerDependenciesMeta": {
    "esbuild": {
      "optional": true
    },
    "esbuild-wasm": {
      "optional": true
    }
  },
  "devDependencies": {
    "esbuild-wasm": "^0.27.3"
  },
  "optionalDependencies": {
    "@oxc-parser/binding-darwin-arm64": "^0.119.0",
    "@oxc-parser/binding-darwin-x64": "^0.119.0",
    "@oxc-parser/binding-linux-arm64-gnu": "^0.119.0",
    "@oxc-parser/binding-linux-arm64-musl": "^0.119.0",
    "@oxc-parser/binding-linux-x64-gnu": "^0.119.0",
    "@oxc-parser/binding-linux-x64-musl": "^0.119.0",
    "@oxc-parser/binding-win32-arm64-msvc": "^0.119.0",
    "@oxc-parser/binding-win32-x64-msvc": "^0.119.0"
  }
}
