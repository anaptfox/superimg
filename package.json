{
  "name": "superimg-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "SuperImg monorepo",
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "build": "pnpm -r --filter '!docs' build",
    "rebuild": "pnpm -r clean && pnpm -r --filter '!docs' build",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test -- --coverage",
    "clean": "pnpm -r clean",
    "lint": "pnpm -r lint",
    "videos": "node ./apps/superimg/dist/cli.js dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  },
  "devDependencies": {
    "@types/node": "^25.0.9",
    "@vitest/coverage-v8": "^4.0.18",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@shikijs/langs": "^4.0.2",
    "@shikijs/themes": "^4.0.2",
    "esbuild": "^0.27.2"
  }
}
